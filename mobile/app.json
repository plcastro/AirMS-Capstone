{
  "expo": {
    "name": "AirMS",
    "slug": "AirMS",
    "scheme": "airms",
    "platforms": ["ios", "android", "web"],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/AirMS_mobile.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/AirMS_web.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.com.ngcp-aviation-dept.airms"
    },
    "android": {
      "package": "com.ngcp-aviation-dept.airms",
      "adaptiveIcon": {
        "foregroundImage": "./assets/AirMS_mobile.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/AirMS_mobile.png"
    },
    "plugins": ["@react-native-community/datetimepicker", "expo-font"]
  }
}
